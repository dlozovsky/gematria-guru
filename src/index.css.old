  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
    font-family: 'Inter', sans-serif;
  }
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-5px); }
    100% { transform: translateY(0px); }
  }
  .float {
    animation: float 4s ease-in-out infinite;
  }
  .glass {
    @apply bg-white/20 backdrop-blur-lg border border-white/20;
  }
  .glass-card {
    @apply bg-white/80 backdrop-blur-sm border border-white/40 shadow-md;
  }
  .glass-input {
    @apply bg-white/60 backdrop-blur-sm border border-white/30 focus:border-primary/30 focus:ring-2 focus:ring-primary/10 transition-all duration-200;
  }
  .transition-fade {
    @apply transition-all duration-300 ease-in-out;
  }
  input, textarea, button, select {
    font-family: inherit;
    @apply focus:outline-none;
  }
