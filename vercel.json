{
  "rewrites": [
    {
      "source": "/((?!api|_next|favicon\\.ico|robots\\.txt|sitemap\\.xml|static|assets).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*[Gg]ooglebot.*"
        }
      ],
      "destination": "/api/prerender?path=/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}
