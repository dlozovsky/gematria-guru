0:["XjciYZ0IZhb4yLvdhaslE",[[["",{"children":["learning",{"children":["advanced",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["learning",{"children":["advanced",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"min-h-screen flex flex-col","children":[["$","$L2",null,{}],["$","main",null,{"className":"flex-1 max-w-3xl mx-auto px-4 py-8 w-full","children":[["$","$L3",null,{"href":"/learning","className":"inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-primary mb-6 transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left h-4 w-4","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Back to Learning Modules"]}],["$","div",null,{"className":"mb-8","children":[["$","h1",null,{"className":"text-3xl font-bold mb-2","children":"Advanced Gematria Techniques"}],["$","p",null,{"className":"text-muted-foreground","children":"Master advanced substitution ciphers and interpretive methods used by Kabbalistic scholars."}]]}],["$","div",null,{"className":"space-y-6","children":[["$","div",null,{"className":"border border-border rounded-xl p-6","children":[["$","h2",null,{"className":"text-xl font-semibold mb-3","children":"AtBash (אתבש)"}],["$","p",null,{"className":"text-muted-foreground mb-3","children":"AtBash is a substitution cipher where the first letter of the alphabet is replaced by the last, the second by the second-to-last, and so on. Aleph becomes Tav, Bet becomes Shin, and so forth. The name itself encodes the pattern: Aleph↔Tav, Bet↔Shin."}],["$","div",null,{"className":"bg-muted/50 rounded-lg p-4 text-sm","children":[["$","p",null,{"className":"font-medium mb-1","children":"Biblical usage"}],["$","p",null,{"className":"text-muted-foreground","children":"The prophet Jeremiah uses AtBash in Jeremiah 25:26 — \"Sheshach\" (ששך) is the AtBash encoding of \"Babel\" (בבל), a veiled reference to Babylon."}]]}]]}],["$","div",null,{"className":"border border-border rounded-xl p-6","children":[["$","h2",null,{"className":"text-xl font-semibold mb-3","children":"Albam (אלבם)"}],["$","p",null,{"className":"text-muted-foreground mb-3","children":"The alphabet is split into two equal halves of 11 letters each. Each letter in the first half is substituted with its corresponding letter in the second half: Aleph↔Lamed, Bet↔Mem, Gimel↔Nun, and so on. The name encodes the first swap: Aleph↔Lamed, Bet↔Mem."}],["$","div",null,{"className":"bg-muted/50 rounded-lg p-4 text-sm","children":[["$","p",null,{"className":"font-medium mb-1","children":"Example"}],["$","p",null,{"className":"text-muted-foreground","children":"The word for heart, לב (Lev, Lamed-Bet), transforms under Albam to אמ — alluding to the idea that the heart conceals the mother (אמ, Em) within it, a Kabbalistic insight."}]]}]]}],["$","div",null,{"className":"border border-border rounded-xl p-6","children":[["$","h2",null,{"className":"text-xl font-semibold mb-3","children":"Ayak Bakar (איק בכר)"}],["$","p",null,{"className":"text-muted-foreground mb-3","children":"In this system, letters that share the same reduced (Mispar Katan) value are considered equivalent and interchangeable. Aleph, Yod, and Qof all reduce to 1; Bet, Kaf, and Resh all reduce to 2, and so on. This creates a nine-cycle grouping system."}],["$","div",null,{"className":"bg-muted/50 rounded-lg p-4 text-sm","children":[["$","p",null,{"className":"font-medium mb-1","children":"Interpretive power"}],["$","p",null,{"className":"text-muted-foreground","children":"By substituting letters within the same Ayak Bakar group, scholars reveal hidden equivalences between words that might seem unrelated on the surface."}]]}]]}],["$","div",null,{"className":"border border-border rounded-xl p-6","children":[["$","h2",null,{"className":"text-xl font-semibold mb-3","children":"Milui (Letter Spelling)"}],["$","p",null,{"className":"text-muted-foreground mb-3","children":"In Milui, each letter is replaced by the sum of the letters that spell its full name. For example, Aleph (אלף) = 1 + 30 + 80 = 111. This dramatically expands numerical values and is used in advanced Kabbalistic calculation, particularly for the Divine Names."}],["$","div",null,{"className":"bg-muted/50 rounded-lg p-4 text-sm","children":[["$","p",null,{"className":"font-medium mb-1","children":"Divine Names"}],["$","p",null,{"className":"text-muted-foreground","children":"Different spellings of the Divine Name (e.g., יהוה) under Milui yield values of 45, 52, 63, or 72 depending on whether vowels are spelled with Aleph, He, Vav, or Yod — each corresponding to a different Kabbalistic world."}]]}]]}]]}],["$","div",null,{"className":"flex items-center justify-between mt-10 pt-6 border-t","children":[["$","$L3",null,{"href":"/learning/systems","className":"flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left h-4 w-4","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Gematria Systems Overview"]}],["$","$L3",null,{"href":"/learning/torah-gematria","className":"flex items-center gap-2 text-sm text-primary font-medium hover:text-primary/80 transition-colors","children":["Torah Gematria",["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-right h-4 w-4","children":[["$","pa